{
  "manifest_version": 2,
  "name": "LM Assistant",
  "version": "1.0.0",
  "description": "Assistant de candidature",
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "permissions": [
    "activeTab",
    "storage",
    "webNavigation",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_title": "LM Assistant",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": []
    }
  ],
  "web_accessible_resources": [
    "popup/popup.html"
  ]
}